<Window x:Class="ProjectInformation.UI.ContactDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contact"
        Width="520"
        Height="520"
        MinWidth="420"
        MinHeight="300"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Text="Naam" FontWeight="SemiBold" />
        <TextBlock Grid.Column="1" Text="{Binding Naam}" TextWrapping="Wrap" />

        <TextBlock Grid.Row="1" Text="Email" FontWeight="SemiBold" Margin="0,10,0,0" />
        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Email}" TextWrapping="Wrap" Margin="0,10,0,0" />

        <TextBlock Grid.Row="2" Text="Aantal mails" FontWeight="SemiBold" Margin="0,10,0,0" />
        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AantalMails}" Margin="0,10,0,0" />

        <TextBlock Grid.Row="3" Text="Laatste contact" FontWeight="SemiBold" Margin="0,10,0,0" />
        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LaatsteContact, StringFormat=yyyy-MM-dd HH:mm}" Margin="0,10,0,0" />

        <TextBlock Grid.Row="4" Text="Company" FontWeight="SemiBold" Margin="0,10,0,0" />
        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Company}" TextWrapping="Wrap" Margin="0,10,0,0" />

        <TextBlock Grid.Row="5" Text="Zakelijk telefoon" FontWeight="SemiBold" Margin="0,10,0,0" />
        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding BusinessTelephoneNumber}" Margin="0,10,0,0" />

        <TextBlock Grid.Row="6" Text="Mobiel" FontWeight="SemiBold" Margin="0,10,0,0" />
        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding MobileTelephoneNumber}" Margin="0,10,0,0" />

        <TextBlock Grid.Row="7" Text="Functie" FontWeight="SemiBold" Margin="0,10,0,0" />
        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding JobTitle}" TextWrapping="Wrap" Margin="0,10,0,0" />

        <TextBlock Grid.Row="8" Text="Projectnummers" FontWeight="SemiBold" Margin="0,10,0,0" />
        <TextBox Grid.Row="8"
                 Grid.Column="1"
                 Text="{Binding Projecten}"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,10,0,0" />

        <Button Grid.Row="9"
                Grid.Column="1"
                Content="Sluiten"
                HorizontalAlignment="Right"
                Padding="16,8"
                Margin="0,16,0,0"
                IsCancel="True" />
    </Grid>
</Window>
