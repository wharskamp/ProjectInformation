<Window x:Class="ProjectInformation.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProjectInformation"
        Height="620"
        Width="1180"
        MinHeight="480"
        MinWidth="720"
        Loaded="WindowLoaded">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Bestand">
                <MenuItem Header="PST importeren" Command="{Binding ImportPstFileCommand}" />
                <MenuItem Header="CSV exporteren" Command="{Binding ExportCsvCommand}" />
                <Separator />
                <MenuItem Header="Afsluiten" Click="ExitMenuItemClick" />
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="Over" Click="AboutMenuItemClick" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding StatisticsText}" />
            <Separator />
            <TextBlock Text="{Binding StatusMessage}" />
        </StatusBar>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="ProjectInformation"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Text="{Binding SelectedPstFilePath, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"
                         Margin="0,0,8,0" />
                <Button Grid.Column="1"
                        Content="Select PST file"
                        Command="{Binding SelectPstFileCommand}"
                        Padding="16,8" />
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="0,24,0,0">
                <Button Content="Import"
                        Command="{Binding ImportCommand}"
                        Padding="18,8"
                        Margin="0,0,8,0" />
                <Button Content="Export CSV"
                        Command="{Binding ExportCsvCommand}"
                        Padding="18,8" />
            </StackPanel>

            <TextBox Grid.Row="3"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,18,0,0"
                     Height="30"
                     VerticalContentAlignment="Center" />

            <DataGrid Grid.Row="4"
                      ItemsSource="{Binding ContactsView}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      Margin="0,12,0,0"
                      MouseDoubleClick="ContactsDataGridMouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Naam" Binding="{Binding Naam}" Width="2*" SortMemberPath="Naam" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*" SortMemberPath="Email" />
                    <DataGridTextColumn Header="Projecten" Binding="{Binding Projecten}" Width="2*" SortMemberPath="Projecten" />
                    <DataGridTextColumn Header="Bedrijf" Binding="{Binding Company}" Width="*" SortMemberPath="Company" />
                    <DataGridTextColumn Header="Telefoon" Binding="{Binding BusinessTelephoneNumber}" Width="*" SortMemberPath="BusinessTelephoneNumber" />
                    <DataGridTextColumn Header="Mobiel" Binding="{Binding MobileTelephoneNumber}" Width="*" SortMemberPath="MobileTelephoneNumber" />
                    <DataGridTextColumn Header="Job Title" Binding="{Binding JobTitle}" Width="*" SortMemberPath="JobTitle" />
                    <DataGridTextColumn Header="LaatsteContact" Binding="{Binding LaatsteContact, StringFormat=yyyy-MM-dd HH:mm}" Width="*" SortMemberPath="LaatsteContact" />
                    <DataGridTextColumn Header="AantalMails" Binding="{Binding AantalMails}" Width="*" SortMemberPath="AantalMails" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>
